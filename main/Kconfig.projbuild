menu "ESP32 NanoBot Configuration"

    menu "AI Provider Settings"
        config AI_PROVIDER_API_KEY
            string "AI Provider API Key"
            default ""
            help
                API key for the AI provider (DeepSeek, Moonshot, etc.)

        config AI_PROVIDER_MODEL
            string "AI Model Name"
            default "deepseek-chat"
            help
                Model name to use for AI completions

        config AI_PROVIDER_TYPE
            string "Provider Type"
            default "deepseek"
            help
                Select AI provider type (deepseek, moonshot, dashscope, etc.)

        config AI_PROVIDER_BASE_URL
            string "Provider Base URL"
            default "https://api.deepseek.com"
            help
                Base URL for the AI provider API
    endmenu

    menu "QQ Bot Settings"
        config QQ_BOT_ENABLED
            bool "Enable QQ Bot"
            default y
            help
                Enable QQ bot integration

        config QQ_APP_ID
            string "QQ App ID"
            default ""
            help
                QQ Open Platform App ID

        config QQ_APP_SECRET
            string "QQ App Secret"
            default ""
            help
                QQ Open Platform App Secret
    endmenu

    menu "Feishu Bot Settings"
        config FEISHU_BOT_ENABLED
            bool "Enable Feishu Bot"
            default y
            help
                Enable Feishu (飞书) bot integration

        config FEISHU_APP_ID
            string "Feishu App ID"
            default ""
            help
                Feishu Open Platform App ID

        config FEISHU_APP_SECRET
            string "Feishu App Secret"
            default ""
            help
                Feishu Open Platform App Secret
    endmenu

    menu "Daily Summary Skill"
        config GIT_REPO_PATH
            string "Git Repository Path"
            default "/sd/git"
            help
                Path to the git repository on SD card

        config SUMMARY_SEND_TIME
            string "Daily Summary Send Time (HH:MM)"
            default "18:00"
            help
                Time to send daily summary (24-hour format)
    endmenu

    menu "Network Settings"
        config WIFI_SSID
            string "WiFi SSID"
            default ""
            help
                WiFi network name

        config WIFI_PASSWORD
            string "WiFi Password"
            default ""
            help
                WiFi password

        config USE_STATIC_IP
            bool "Use Static IP"
            default n
            help
                Use static IP address instead of DHCP

        config STATIC_IP_ADDRESS
            string "Static IP Address"
            default "192.168.1.100"
            help
                Static IP address

        config STATIC_GATEWAY
            string "Default Gateway"
            default "192.168.1.1"
            help
                Default gateway address
    endmenu

endmenu
